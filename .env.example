# LLM Provider: "openai" or "claude" or "gemini"
LLM_PROVIDER=gemini

# OpenAI
OPENAI_API_KEY=sk-...

# Anthropic (Claude)
ANTHROPIC_API_KEY=sk-ant-...

# Gemini (free tier available)
GEMINI_API_KEY=...

# Runtime
SLIDES_PER_POST=6
LOG_LEVEL=INFO

# Accounts config (계정/카테고리 설정 파일 경로)
ACCOUNTS_CONFIG_PATH=accounts.yaml

# Google Drive Upload
GOOGLE_DRIVE_FOLDER_ID=폴더ID
GOOGLE_CREDENTIALS_PATH=credentials.json

# Telegram Notification
TELEGRAM_BOT_TOKEN=토큰
TELEGRAM_CHAT_ID=채팅ID
